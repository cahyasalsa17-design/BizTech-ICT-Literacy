rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTeacher() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUser(data) {
      let requiredFields = ['uid', 'email', 'displayName', 'role', 'createdAt', 'scores', 'progress'];
      return data.keys().hasAll(requiredFields)
        && data.keys().size() == 7
        && data.uid == request.auth.uid
        && data.email is string
        && data.role in ['student', 'teacher']
        && data.displayName is string && data.displayName.size() <= 100
        && data.createdAt is timestamp
        && data.scores is map
        && data.progress is map;
    }

    // Module Validation
    function isValidModule(data) {
      let requiredFields = ['title', 'description', 'duration', 'subTopics', 'quiz'];
      return data.keys().hasAll(requiredFields)
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.duration is string && data.duration.size() <= 50
        && data.subTopics is list
        && data.quiz is list;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;

      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().createdAt == request.time;

      allow update: if isOwner(userId)
        && isValidUser(incoming())
        && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'scores', 'progress', 'role']))
        )
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().createdAt == existing().createdAt;

      allow delete: if false;
    }

    match /modules/{moduleId} {
      allow get, list: if true;
      allow create: if isTeacher() 
        && isValidId(moduleId)
        && isValidModule(incoming())
        && incoming().createdAt == request.time;
      
      allow update: if isTeacher()
        && isValidModule(incoming())
        && (incoming().diff(existing()).affectedKeys().hasAll([]))
        && (incoming().updatedAt == request.time || !incoming().keys().hasAny(['updatedAt']));
      
      allow delete: if isTeacher();
    }
  }
}
